# Docker Compose loads .env from the directory where you run `docker compose up`.
# All ${VAR} references below are resolved from that file automatically —
# no env_file directive needed for compose-level substitution.
services:
{{- if .HasDB.postgres }}
  postgres:
    image: postgres:16-alpine
    restart: unless-stopped
    ports: ["5432:5432"]
    environment:
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: ${POSTGRES_DB:-{{ .Name }}}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks: [{{ .Name }}_net]
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-postgres}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
{{- end }}
{{- if .HasDB.mysql }}
  mysql:
    image: mysql:8.4
    restart: unless-stopped
    ports: ["3306:3306"]
    environment:
      MYSQL_ROOT_PASSWORD: ${MYSQL_PASSWORD}
      MYSQL_DATABASE: ${MYSQL_DB:-{{ .Name }}}
    volumes:
      - mysql_data:/var/lib/mysql
    networks: [{{ .Name }}_net]
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost", "--silent"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
{{- end }}
{{- if .HasDB.mongo }}
  mongo:
    image: mongo:7
    restart: unless-stopped
    ports: ["27017:27017"]
    volumes:
      - mongo_data:/data/db
    networks: [{{ .Name }}_net]
    healthcheck:
      test: ["CMD", "mongosh", "--eval", "db.adminCommand('ping')"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 20s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
{{- end }}
{{- if .HasDB.redis }}
  redis:
    image: redis:7-alpine
    restart: unless-stopped
    ports: ["6379:6379"]
    # --save 60 1: snapshot every 60 s if at least 1 key changed (AOF not enabled by default)
    command: redis-server --requirepass ${REDIS_PASSWORD} --save 60 1 --loglevel warning
    environment:
      REDIS_PASSWORD: ${REDIS_PASSWORD}
    volumes:
      - redis_data:/data
    networks: [{{ .Name }}_net]
    healthcheck:
      test: ["CMD-SHELL", "redis-cli -a $$REDIS_PASSWORD ping | grep PONG"]
      interval: 10s
      timeout: 5s
      retries: 5
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
{{- end }}
{{- if .HasDB.cassandra }}
  cassandra:
    image: cassandra:4
    restart: unless-stopped
    ports: ["9042:9042"]
    environment:
      CASSANDRA_CLUSTER_NAME: ${CASSANDRA_CLUSTER_NAME:-{{ .Name }}-cluster}
      # JVM heap — keep below half of container memory
      MAX_HEAP_SIZE: 512M
      HEAP_NEWSIZE: 128M
    volumes:
      - cassandra_data:/var/lib/cassandra
    networks: [{{ .Name }}_net]
    healthcheck:
      test: ["CMD-SHELL", "cqlsh -e 'describe keyspaces' || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 10
      start_period: 60s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
{{- end }}
{{- if .HasAddon.docker }}
  app:
    build:
      context: ..
      dockerfile: deploy/Dockerfile
    restart: unless-stopped
    ports: ["8080:8080"]
    env_file:
      - ../.env
    depends_on:
{{- if .HasDB.postgres }}
      postgres:
        condition: service_healthy
{{- end }}
{{- if .HasDB.mysql }}
      mysql:
        condition: service_healthy
{{- end }}
{{- if .HasDB.mongo }}
      mongo:
        condition: service_healthy
{{- end }}
{{- if .HasDB.redis }}
      redis:
        condition: service_healthy
{{- end }}
{{- if .HasDB.cassandra }}
      cassandra:
        condition: service_healthy
{{- end }}
    networks: [{{ .Name }}_net]
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
{{- end }}

networks:
  {{ .Name }}_net:

{{ if or .HasDB.postgres .HasDB.mysql .HasDB.mongo .HasDB.redis .HasDB.cassandra -}}
volumes:
{{- if .HasDB.postgres }}
  postgres_data:
{{- end }}
{{- if .HasDB.mysql }}
  mysql_data:
{{- end }}
{{- if .HasDB.mongo }}
  mongo_data:
{{- end }}
{{- if .HasDB.redis }}
  redis_data:
{{- end }}
{{- if .HasDB.cassandra }}
  cassandra_data:
{{- end }}
{{ end -}}
