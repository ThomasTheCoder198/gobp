// Package controller holds HTTP request handlers. Structs in this package end
// with "Controller" by convention.
package controller

import (
	"net/http"

	"github.com/gin-gonic/gin"
)

// HealthController serves the /healthz liveness check.
type HealthController struct{}

// NewHealthController is the Wire provider.
func NewHealthController() *HealthController { return &HealthController{} }

// Register attaches the controller's routes to the given router group.
func (h *HealthController) Register(rg *gin.RouterGroup) {
	rg.GET("/healthz", h.Health)
}

// Health returns 200 with a small status payload, including trace_id from context.
func (h *HealthController) Health(c *gin.Context) {
	c.JSON(http.StatusOK, gin.H{
		"status":   "ok",
		"trace_id": c.GetString("trace_id"),
	})
}
