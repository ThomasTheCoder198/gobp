package utils

// SuccessResponse is the standard envelope for a single-resource response.
type SuccessResponse[T any] struct {
	Data T `json:"data"`
}

// PaginatedResponse is the standard envelope for a paginated list response.
type PaginatedResponse[T any] struct {
	Data       []T            `json:"data"`
	Pagination PaginationMeta `json:"pagination"`
}

// MessageResponse is a simple acknowledgment body (create, delete, etc.).
type MessageResponse struct {
	Message string `json:"message"`
}

// Success wraps data in a SuccessResponse.
//
//	ctx.JSON(http.StatusOK, utils.Success(user))
func Success[T any](data T) SuccessResponse[T] {
	return SuccessResponse[T]{Data: data}
}

// Paginated wraps a list and its meta in a PaginatedResponse.
//
//	ctx.JSON(http.StatusOK, utils.Paginated(users, meta))
func Paginated[T any](data []T, meta PaginationMeta) PaginatedResponse[T] {
	if data == nil {
		data = []T{}
	}
	return PaginatedResponse[T]{Data: data, Pagination: meta}
}

// Message returns a simple message response.
func Message(msg string) MessageResponse { return MessageResponse{Message: msg} }
