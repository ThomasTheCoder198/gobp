// Package openai wraps the OpenAI client behind a thin Client type so the
// rest of the project depends on this package, not the SDK directly.
package openai

import (
	"context"
	"fmt"

	openai "github.com/sashabaranov/go-openai"
)

// Config carries the inputs needed to build the client.
type Config struct {
	APIKey string
}

// Client is the project-level OpenAI handle.
type Client struct {
	c *openai.Client
}

// New builds a *Client. No network call is made.
func New(cfg Config) *Client {
	return &Client{c: openai.NewClient(cfg.APIKey)}
}

// Ping does a lightweight liveness check (lists models).
func (c *Client) Ping(ctx context.Context) error {
	_, err := c.c.ListModels(ctx)
	if err != nil {
		return fmt.Errorf("openai ping: %w", err)
	}
	return nil
}

// Raw exposes the underlying SDK client for direct use.
func (c *Client) Raw() *openai.Client { return c.c }
