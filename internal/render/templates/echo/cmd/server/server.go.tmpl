package main

import (
	"github.com/labstack/echo/v4"
	"go.uber.org/zap"

	"{{ .Module }}/internal/server/middleware"
)

// Server wraps the Wire-injected App and provides centralised route
// registration. Add new controllers to App (via wire.go) and register
// their routes in RegisterRoutes.
type Server struct {
	app    *App
	logger *zap.Logger
}

// NewServer creates a ready-to-use Server.
func NewServer(app *App, logger *zap.Logger) *Server {
	return &Server{app: app, logger: logger}
}

// RegisterRoutes attaches all middleware and route groups to the Echo instance.
func (s *Server) RegisterRoutes(e *echo.Echo) {
	// CORS must be first to handle OPTIONS preflight before auth/tracing hits.
	// Pass allowed origins explicitly in production: middleware.CORS("https://example.com")
	e.Use(middleware.CORS())
	e.Use(middleware.TraceID())
	e.Use(middleware.AccessLog(s.logger))
	e.Use(middleware.Recovery(s.logger))
	e.HTTPErrorHandler = middleware.ErrorHandler(s.logger)

	api := e.Group("")
	s.app.Health.Register(api)
{{- if .Websocket }}
	s.app.WS.Register(api)
{{- end }}

