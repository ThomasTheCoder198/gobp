# Local secrets — gitignored. Copied from .env.example.

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development
SERVER_PORT=8080
LOG_LEVEL=info
{{ if .HasDB.postgres -}}
# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB={{ .Name }}
{{ end -}}
{{ if .HasDB.mysql -}}
# ── MySQL ──────────────────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB={{ .Name }}
{{ end -}}
{{ if .HasDB.mongo -}}
# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB={{ .Name }}
{{ end -}}
{{ if .HasDB.redis -}}
# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
{{ end -}}
{{ if .HasDB.cassandra -}}
# ── Cassandra ──────────────────────────────────────────────────────────────────
CASSANDRA_HOSTS=localhost
CASSANDRA_KEYSPACE={{ .Name }}
CASSANDRA_CLUSTER_NAME={{ .Name }}-cluster
{{ end -}}
{{ if .HasSDK.openai -}}
# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
{{ end -}}
{{ if .HasSDK.stripe -}}
# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_API_KEY=
{{ end -}}
