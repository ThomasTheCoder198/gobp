# Committed example — safe to commit, no real secrets.
# Copy to .env and fill in values before running the app.

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development
SERVER_PORT=8080
LOG_LEVEL=info
{{ if .HasDB.postgres -}}
# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
{{ end -}}
{{ if .HasDB.mysql -}}
# ── MySQL ──────────────────────────────────────────────────────────────────────
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DB=
{{ end -}}
{{ if .HasDB.mongo -}}
# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_URI=
MONGO_DB=
{{ end -}}
{{ if .HasDB.redis -}}
# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_ADDR=
REDIS_PASSWORD=
{{ end -}}
{{ if .HasDB.cassandra -}}
# ── Cassandra ──────────────────────────────────────────────────────────────────
CASSANDRA_HOSTS=
CASSANDRA_KEYSPACE=
CASSANDRA_CLUSTER_NAME=
{{ end -}}
{{ if .HasSDK.openai -}}
# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
{{ end -}}
{{ if .HasSDK.stripe -}}
# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_API_KEY=
{{ end -}}
